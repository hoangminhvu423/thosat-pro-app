    { "ten": "cao_tam",   "cong_thuc": "H*1000 - cao_tay_vin - cao_thanh_de" },
    { "ten": "dt_cnc",    "cong_thuc": "so_khoang * khoang_tt * cao_tam / 1000000" }
  ],
